{
  "name": "simply-static-nextjs",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-11",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "directory": "./out/",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  }
}